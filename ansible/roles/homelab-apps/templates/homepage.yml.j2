---
services:
  homepage:
    container_name: homepage
    image: gethomepage/homepage:latest
    environment:
      HOMEPAGE_ALLOWED_HOSTS: "homepage.lab,192.168.40.142,192.168.40.143,192.168.40.141,localhost"
    ports:
      - "3000:3000"
    volumes:
      - ./config:/app/config
      - /var/run/docker.sock:/var/run/docker.sock:ro
    restart: unless-stopped