---
- Sieć:
    - Pi-hole:
        icon: pi-hole
        href: http://pihole.lab
        description: DNS sinkhole & blocker
        widget:
          type: pihole
          url: http://{{ hostvars['dns-01']['ansible_host'] | default('192.168.40.141') }}
          key: {{ pihole_api_key | default('') }}
          version: 5

    - Traefik:
        icon: traefik
        href: http://traefik.lab
        description: Reverse proxy & load balancer
        widget:
          type: traefik
          url: http://{{ hostvars['proxy-01']['ansible_host'] | default('192.168.40.142') }}:8080

- Monitoring:
    - Grafana:
        icon: grafana
        href: http://grafana.lab
        description: Dashboardy i metryki
        widget:
          type: grafana
          url: http://{{ hostvars['monitor-01']['ansible_host'] | default('192.168.40.145') }}:3000
          username: admin
          password: changeme

    - Prometheus:
        icon: prometheus
        href: http://prometheus.lab
        description: Zbieranie metryk
        widget:
          type: prometheus
          url: http://{{ hostvars['monitor-01']['ansible_host'] | default('192.168.40.145') }}:9090

    - Alertmanager:
        icon: alertmanager
        href: http://alertmanager.lab
        description: Zarządzanie alertami
        widget:
          type: alertmanager
          url: http://{{ hostvars['monitor-01']['ansible_host'] | default('192.168.40.145') }}:9093

    - Uptime Kuma:
        icon: uptime-kuma
        href: http://kuma.lab
        description: Monitoring uptime usług
        widget:
          type: uptimekuma
          url: http://{{ ansible_host }}:3001

    - Portainer:
        icon: portainer
        href: https://{{ ansible_host }}:9443
        description: Zarządzanie kontenerami Docker

- Aplikacje:
    - Paperless:
        icon: paperless-ngx
        href: http://paperless.lab
        description: Zarządzanie dokumentami
        widget:
          type: paperlessngx
          url: http://{{ hostvars['app-01']['ansible_host'] | default('192.168.40.143') }}:8001

    - Homepage:
        icon: homepage
        href: http://homepage.lab
        description: Ten dashboard

- Infrastruktura:
    - Assistant-01:
        icon: si-openai
        href: "#"
        description: AI / assistants VM
        statusStyle: basic

    - Proxmox:
        icon: proxmox
        href: https://192.168.40.1:8006
        description: Proxmox VE
        statusStyle: basic