---
http:
  routers:
    kuma:
      rule: Host(`kuma.lab`)
      service: kuma
      entryPoints:
        - web

    homepage:
      rule: Host(`homepage.lab`)
      service: homepage
      entryPoints:
        - web

    paperless:
      rule: Host(`paperless.lab`)
      service: paperless
      entryPoints:
        - web

    grafana:
      rule: Host(`grafana.lab`)
      service: grafana
      entryPoints:
        - web

    prometheus:
      rule: Host(`prometheus.lab`)
      service: prometheus
      entryPoints:
        - web

    alertmanager:
      rule: Host(`alertmanager.lab`)
      service: alertmanager
      entryPoints:
        - web

  services:
    kuma:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars['app-01']['ansible_host'] | default('192.168.40.143') }}:3001"

    homepage:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars['app-01']['ansible_host'] | default('192.168.40.143') }}:3000"

    paperless:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars['app-01']['ansible_host'] | default('192.168.40.143') }}:8001"

    grafana:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars['monitor-01']['ansible_host'] | default('192.168.40.145') }}:3000"

    prometheus:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars['monitor-01']['ansible_host'] | default('192.168.40.145') }}:9090"

    alertmanager:
      loadBalancer:
        servers:
          - url: "http://{{ hostvars['monitor-01']['ansible_host'] | default('192.168.40.145') }}:9093"
