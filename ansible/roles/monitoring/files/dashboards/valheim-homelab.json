{
  "annotations": {
    "list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Server Status",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "index": 1, "text": "OFFLINE"}, "1": {"color": "green", "index": 0, "text": "ONLINE"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(valheim_online{version!=\"Unknown\"})", "refId": "A"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Players Online",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(valheim_current_player_count{version!=\"Unknown\"})", "refId": "A"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Max Players",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value"},
      "targets": [{"expr": "max(valheim_max_player_count{version!=\"Unknown\"})", "refId": "A"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "World",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "semi-dark-blue", "value": null}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "name"},
      "targets": [{"expr": "max(valheim_online{name=\"PORTPOLSKA\",version!=\"Unknown\"})", "legendFormat": "{{map}}", "refId": "A"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Version",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "dark-gray", "value": null}]}}},
      "options": {"colorMode": "none", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "name"},
      "targets": [{"expr": "max(valheim_online{version!=\"Unknown\"})", "legendFormat": "{{version}}", "refId": "A"}]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Players Online Over Time",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "stacking": {"mode": "none"}},
          "unit": "short"
        }
      },
      "options": {"legend": {"showLegend": false}, "tooltip": {"mode": "single"}},
      "targets": [{"expr": "valheim_current_player_count", "legendFormat": "Players", "refId": "A"}]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Server CPU Usage",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "stacking": {"mode": "none"}},
          "unit": "percent"
        }
      },
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {"expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\",instance=\"192.168.40.221:9100\"}[5m])) * 100)", "legendFormat": "Total CPU", "refId": "A"},
        {"expr": "valheim_sys_load_average{window=\"1m\"}", "legendFormat": "Load 1m", "refId": "B"}
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "stacking": {"mode": "none"}},
          "unit": "bytes"
        }
      },
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {"expr": "valheim_sys_memory_used_bytes", "legendFormat": "VM Used", "refId": "A"},
        {"expr": "valheim_sys_memory_total_bytes", "legendFormat": "VM Total", "refId": "B"},
        {"expr": "node_memory_MemTotal_bytes{instance=\"192.168.40.221:9100\"} - node_memory_MemAvailable_bytes{instance=\"192.168.40.221:9100\"}", "legendFormat": "Host Used", "refId": "C"}
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "stacking": {"mode": "none"}},
          "unit": "bps"
        }
      },
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total{instance=\"192.168.40.221:9100\",device!=\"lo\"}[5m]) * 8", "legendFormat": "{{device}} RX", "refId": "A"},
        {"expr": "-rate(node_network_transmit_bytes_total{instance=\"192.168.40.221:9100\",device!=\"lo\"}[5m]) * 8", "legendFormat": "{{device}} TX", "refId": "B"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Disk Usage",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "stacking": {"mode": "none"}},
          "unit": "percent"
        }
      },
      "options": {"legend": {"showLegend": true, "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {"expr": "100 - ((valheim_sys_disk_available_bytes * 100) / valheim_sys_disk_total_bytes)", "legendFormat": "Disk Used %", "refId": "A"},
        {"expr": "100 - ((node_filesystem_avail_bytes{instance=\"192.168.40.221:9100\",mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{instance=\"192.168.40.221:9100\",mountpoint=\"/\"})", "legendFormat": "Host / Used %", "refId": "B"}
      ]
    },
    {
      "id": 30,
      "type": "logs",
      "title": "Server Logs (Loki)",
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "options": {"showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": false, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending"},
      "targets": [
        {"expr": "{service_name=\"valheim\"}", "refId": "A"}
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": ["homelab", "valheim", "gaming"],
  "templating": {
    "list": [
      {"current": {"selected": false, "text": "Prometheus", "value": "prometheus"}, "hide": 0, "label": "Datasource", "name": "datasource", "query": "prometheus", "type": "datasource"},
      {"current": {"selected": false, "text": "Loki", "value": "loki"}, "hide": 0, "label": "Loki Datasource", "name": "loki_datasource", "query": "loki", "type": "datasource"}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Valheim Homelab",
  "uid": "valheim-homelab",
  "version": 2,
  "weekStart": ""
}
