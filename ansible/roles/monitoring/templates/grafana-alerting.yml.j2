apiVersion: 1

contactPoints:
  - orgId: 1
    name: alertmanager
    receivers:
      - uid: am-telegram
        type: prometheus-alertmanager
        settings:
          url: http://alertmanager:9093
        disableResolveMessage: false

policies:
  - orgId: 1
    receiver: alertmanager
    group_by:
      - alertname
    group_wait: 10s
    group_interval: 10s
    repeat_interval: 4h
